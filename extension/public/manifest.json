{
  "manifest_version": 3,
  "name": "whytab",
  "description": "A local-first new tab dashboard for shortcuts, widgets, notes, todos, weather, and optional sync.",
  "version": "0.5.4",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "geolocation"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://keafulupzvfljvbzwgrq.supabase.co/*",
    "https://whytab.pages.dev/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
